<launch>
    <!-- 定义一个参数，允许从命令行接收rosbag路径 -->
    <arg name="rosbag_path" default="/home/comb/0720.bag"/>
    <arg name="current_position_x" default="0.23"/>
    <arg name="current_position_y" default="8.10"/>
    <!-- 启动waypoint_tracker节点 -->
    <node pkg="offboard_pkg" type="offboard_rosbag" name="waypoint_tracker" output="screen" >
        <!-- 使用传入的参数设置rosbag路径参数 -->
        <param name="rosbag_path" value="$(arg rosbag_path)" />
        <param name="current_position_x" value="$(arg current_position_x)" />
        <param name="current_position_y" value="$(arg current_position_y)" />
    </node>
</launch>